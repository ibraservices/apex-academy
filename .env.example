# إعدادات الاتصال بقاعدة بيانات Supabase
# انسخ هذا الملف باسم .env واملأ القيم التالية للربط بقاعدة البيانات الفعلية
# في حال عدم ملء هذه القيم، سيعمل التطبيق تلقائياً على نظام التخزين المحلي (LocalStorage) لتسهيل التجربة

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
